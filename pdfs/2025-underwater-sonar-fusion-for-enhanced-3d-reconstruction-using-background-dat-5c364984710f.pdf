		$("div.NURIMEDIAXML img").click(function() { 
			if( $(this).hasClass('xml_graphic') ) {

				var m = $(this).attr("src"); 
				if(m.substr(0,4) != "/xml") return;			
				var imgw = window.open('/_common/vw_image.php?m=' + encodeURI(m), 'imgwin', 'width=600, height=400, resizable=1, scrollbars=1, status=1');
				imgw.focus();
			}
		});


		$.ajax({
			url : "./citedLink.php",
			dataType:"text",
			type:"POST",
			data:{"doi":doi, "domainid":domainid},
			success:function(data)
			{
				$('#citedLink').html(data);
				$.ajax({
					url : "./citedLinkList.php",
					dataType:"text",
					type:"POST",
					data:{"doi":doi, "domainid":domainid},
					success:function(data)
					{						
						$('#citedLinkList').css("display","none");
						$('#citedLinkList').html(data);
						var contributor = $("contributor").last(); 
						$('#citedLinkTR').css("display","");
						
						$("contributor").last().text(contributor.text().replace(/;/,''));
					}
				});
			}
		});


