		var initPosition = parseInt($("#Xslidemenu").css("top"));
		$(window).scroll(function() {
			if (document.compatMode && document.compatMode != 'BackCompat') {
				position = document.documentElement.scrollTop;
			}
			else {
				position = document.body.scrollTop;
			}
			$("#Xslidemenu").css({"right":"0px"});
			$("#Xslidemenu").stop().animate({"top":position + initPosition+"px"},1000);
		});
	});
</script>


<style type="text/css">
#Xslidemenu { z-index:10; position:absolute; top:280px; right:15px;}
</style>

<div id="Xslidemenu">
	<table border=0 align=right cellpadding=1 cellspacing=0>
		<tr><td align=right><a href="#" onClick="this.blur()"><img src="/_common/images/quickTop.png"></a></td></tr>
		<tr><td align=right><a href="#__bottom" onClick="this.blur()"><img src="/_common/images/quickBottom.png"></a></td></tr>
	</table>
</div>
</div>
<form name='bsF' method='post'>
	<input type="hidden" name="now_book_name" value="JOURNAL OF SENSOR SCIENCE AND TECHNOLOGY">
	<input type="hidden" name="a" value="full">
	<input type="hidden" name="b" value="42">
	<input type="hidden" name="aidx" value="">
	<input type="hidden" name="bidx" value="4212">
</form>

<script>
	function doChangeGroup(obj) {
		with(document.bsF) {
			bidx.value = "";
			now_book_name.value = obj.value
			submit();
		}
	}
	function gotoVolList(idx) {
		with(document.bsF) {
			bidx.value = idx;
			submit();
		}
	}
	function gotoPaperList() {
		with(document.bsF) {
			aidx.value = "";
			submit();
		}
	}
	
	function doSelectBook(no) {
		with(document.bsF) {
			bidx.value = no;
			submit();
		}
	}
</script>


		</div>
