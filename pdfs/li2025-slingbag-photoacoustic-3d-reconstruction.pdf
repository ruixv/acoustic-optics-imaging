        <h3 class="c-article__sub-heading">Subjects</h3>
        <ul class="c-article-subject-list">
            <li class="c-article-subject-list__subject"><a href="/subjects/biomedical-engineering" data-track="click" data-track-action="view subject" data-track-label="link">Biomedical engineering</a></li><li class="c-article-subject-list__subject"><a href="/subjects/computational-science" data-track="click" data-track-action="view subject" data-track-label="link">Computational science</a></li>
